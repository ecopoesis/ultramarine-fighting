{
  "name": "lobsters-prototype",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Decoupled TS engine for the Lobsters euro board game prototype (hot-seat). Pen-and-paper is the real target.",
  "scripts": {
    "play": "tsx scripts/playRandomGame.ts",
    "sim": "tsx scripts/playRandomGame.ts 200",
    "arena": "tsx scripts/arena.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "typecheck:web": "tsc -p tsconfig.web.json --noEmit",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.20.0",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "jsdom": "^29.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vite": "^5.4.21",
    "vitest": "^2.1.8"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "esbuild@0.21.5": true
  }
}
