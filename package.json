{
  "name": "lobsters-prototype",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Decoupled TS engine for the Lobsters euro board game prototype (hot-seat). Pen-and-paper is the real target.",
  "scripts": {
    "play": "tsx scripts/playRandomGame.ts",
